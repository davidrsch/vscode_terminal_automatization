{
  "name": "terminal-automatization",
  "displayName": "Terminal Automatization MCP",
  "description": "MCP server for managing VS Code terminals — list, rename, navigate, create, close, split, and send commands",
  "version": "0.1.4",
  "publisher": "davidrsch",
  "icon": "logo.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/davidrsch/vscode_terminal_automatization"
  },
  "engines": {
    "vscode": "^1.99.0"
  },
  "categories": ["AI", "Other"],
  "keywords": [
    "mcp",
    "terminal",
    "ai",
    "copilot",
    "model context protocol",
    "vscode",
    "terminal management"
  ],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "terminal-automatization.showStatus",
        "title": "Show Status",
        "category": "Terminal MCP"
      },
      {
        "command": "terminal-automatization.copyMcpConfig",
        "title": "Copy MCP Configuration",
        "category": "Terminal MCP"
      },
      {
        "command": "terminal-automatization.addToMcpJson",
        "title": "Add to .vscode/mcp.json",
        "category": "Terminal MCP"
      },
      {
        "command": "terminal-automatization.restart",
        "title": "Restart Server",
        "category": "Terminal MCP"
      }
    ],
    "configuration": {
      "title": "Terminal MCP",
      "properties": {
        "terminalMcp.port": {
          "type": "number",
          "default": 6070,
          "minimum": 1024,
          "maximum": 65535,
          "description": "Port for the Terminal MCP server (default: 6070)"
        },
        "terminalMcp.autoConfigureMcpJson": {
          "type": "boolean",
          "default": false,
          "description": "Manually add the server to .vscode/mcp.json for non-VS Code MCP clients"
        }
      }
    },
    "mcpServerDefinitionProviders": [
      {
        "id": "terminalMcp",
        "label": "Terminal Automatization MCP"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "node esbuild.js --production",
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest",
    "package": "vsce package --no-dependencies",
    "publish": "vsce publish --no-dependencies"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.99.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.25.0",
    "eslint": "^9.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.9.0",
    "express": "^4.21.0"
  }
}
